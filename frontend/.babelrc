{
  "sourceType": "unambiguous",
  "presets": [
    "@babel/preset-env",
    // "@babel/preset-react",
    "@babel/preset-typescript",
    [
      "@babel/preset-react",
      {
        "throwIfNamespace": false // defaults to true
      }
    ]
  ],
  "plugins": ["@babel/plugin-transform-runtime"]
}
